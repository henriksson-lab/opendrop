// About dialog — an in-window modal overlay (works identically on every
// platform). A dimmed backdrop closes it on click; the card holds app info.

import { Theme } from "theme.slint";
import { Button, Card } from "widgets.slint";

export component AboutDialog inherits Rectangle {
    in property <string> version;
    callback close();
    // Dimmed, click-catching backdrop.
    background: #0b1220bf;

    TouchArea { clicked => { root.close(); } }

    Card {
        width: 380px;
        height: 260px;
        // Swallow clicks so tapping the card does not close the dialog.
        TouchArea {}

        VerticalLayout {
            padding: 24px;
            spacing: 10px;
            alignment: center;

            Text {
                text: "OpenDrop";
                font-size: 26px;
                font-weight: 800;
                color: Theme.accent;
                horizontal-alignment: center;
            }
            Text {
                text: "Version " + root.version;
                font-size: 12px;
                color: Theme.text-muted;
                horizontal-alignment: center;
            }
            Rectangle { height: 6px; }
            Text {
                text: "An open-source GUI for the Thermo Scientific\nNanoDrop ND-1000 microvolume spectrophotometer.";
                font-size: 13px;
                color: Theme.text;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
            Text {
                text: "MIT / Apache-2.0 licensed";
                font-size: 11px;
                color: Theme.text-faint;
                horizontal-alignment: center;
            }
            Rectangle { height: 6px; }
            HorizontalLayout {
                alignment: center;
                Button {
                    text: "Close";
                    primary: true;
                    clicked => { root.close(); }
                }
            }
        }
    }
}
