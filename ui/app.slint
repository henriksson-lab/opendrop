// OpenDrop — single-window application shell.
//
// `AppWindow` stays the exported root so `include_modules!()` in main.rs keeps
// working. It owns all view state (driven by the Rust controller) and lays out,
// top to bottom: a native menu bar, a compact measurement toolbar, the overlaid
// spectrum plot, and the samples table. The About dialog is an overlay toggled
// entirely in the UI.

import { ComboBox, LineEdit } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { Button, Card } from "widgets.slint";
import { SpectrumPlot } from "plot.slint";
import { SamplesTable } from "samples_table.slint";
import { AboutDialog } from "about.slint";
import { InputDialog } from "input_dialog.slint";
import { MessageDialog } from "message_dialog.slint";
import { BusyDialog } from "busy_dialog.slint";
import { PlotTrace, SampleRow } from "types.slint";

export { PlotTrace, SampleRow }

export component AppWindow inherits Window {
    title: "OpenDrop";
    default-font-size: 13px;
    background: Theme.window-bg;
    preferred-width: 1120px;
    preferred-height: 760px;
    min-width: 940px;
    min-height: 620px;

    // ---- View state (driven by the Rust controller) ----
    in property <[PlotTrace]> traces;
    in property <string> y-max-label: "1.0";
    in property <[SampleRow]> samples;
    in property <bool> has-blank: false;
    // Exactly one sample selected — gates Measure (it writes one sample).
    in property <bool> single-selected: false;
    // Trailing glyph on the Blank / Re-blank buttons: 0 none, 1 OK, 2 failed.
    // Each reflects only its own last press (the other is cleared).
    in property <int> blank-status: 0;
    in property <int> reblank-status: 0;
    in property <string> status-text: "Click Blank to record a reference, then Measure.";
    in property <string> device-text: "";
    in property <string> version: "0.1.0";
    in-out property <int> sample-type-index: 0;
    // Custom ng/µL-per-AU constant shown as the 4th "Custom (…)" type.
    in-out property <string> custom-constant: "30";
    in-out property <string> rename-text: "";
    // New-sample dialog state (opened/prefilled by the controller).
    in-out property <bool> new-sample-open: false;
    in-out property <string> new-sample-name: "";
    // Add-custom dialog state.
    in-out property <bool> custom-open: false;
    in-out property <string> custom-input: "";
    // Busy overlay shown during the (simulated) acquisition.
    in property <bool> busy-open: false;
    in property <string> busy-text: "Measuring…";
    // "Overwrite existing data?" confirmation before re-measuring a filled row.
    in-out property <bool> confirm-overwrite-open: false;
    in property <string> confirm-text: "";
    // "Blank check failed" alert.
    in-out property <bool> blank-fail-open: false;
    in property <string> blank-fail-text: "";

    // ---- Callbacks handled in Rust ----
    callback measure();
    callback confirm-overwrite();
    callback next-sample();
    callback blank();
    callback reblank();
    callback sample-type-changed(int);
    callback select-row(int, bool);
    callback rename-selected(string);
    callback request-new-sample();
    callback create-sample(string);
    callback request-custom();
    callback set-custom(string);
    callback export-pdf();
    callback remove-selected();
    callback clear-all();
    callback request-quit();

    // About overlay is UI-local state.
    property <bool> about-open: false;

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "Export PDF…";
                activated => { root.export-pdf(); }
            }
            MenuSeparator {}
            MenuItem {
                title: "Quit";
                activated => { root.request-quit(); }
            }
        }
        Menu {
            title: "Edit";
            MenuItem {
                title: "Remove Selected Samples";
                activated => { root.remove-selected(); }
            }
            MenuItem {
                title: "Clear All Samples";
                activated => { root.clear-all(); }
            }
        }
        Menu {
            title: "Help";
            MenuItem {
                title: "About OpenDrop";
                activated => { root.about-open = true; }
            }
        }
    }

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        // ---- Measurement toolbar ----
        Card {
            height: 58px;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 10px;

                VerticalLayout {
                    alignment: center;
                    ComboBox {
                        width: 148px;
                        model: [
                            "dsDNA (50)",
                            "RNA (40)",
                            "ssDNA (33)",
                            "Custom (" + root.custom-constant + ")",
                        ];
                        current-index <=> root.sample-type-index;
                        selected(txt) => { root.sample-type-changed(self.current-index); }
                    }
                }

                // Set the custom conversion constant via a dialog.
                VerticalLayout {
                    alignment: center;
                    Button {
                        text: "Add constant";
                        clicked => { root.request-custom(); }
                    }
                }

                // Action buttons, vertically centred.
                VerticalLayout {
                    alignment: center;
                    HorizontalLayout {
                        spacing: 8px;
                        Button {
                            text: "New sample";
                            clicked => { root.request-new-sample(); }
                        }
                        Button {
                            text: "Blank";
                            status: root.blank-status;
                            clicked => { root.blank(); }
                        }
                        Button {
                            text: "Re-blank";
                            status: root.reblank-status;
                            enabled: root.has-blank;
                            clicked => { root.reblank(); }
                        }
                        Button {
                            text: "Measure";
                            primary: true;
                            // One sample must be selected — Measure writes it.
                            enabled: root.has-blank && root.single-selected;
                            clicked => { root.measure(); }
                        }
                        Button {
                            text: "Next";
                            clicked => { root.next-sample(); }
                        }
                    }
                }

                // Status message fills the rest of the toolbar.
                Rectangle {
                    horizontal-stretch: 1;
                    min-width: 60px;
                    Text {
                        text: root.status-text;
                        font-size: 11px;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        x: 4px;
                        width: parent.width - 8px;
                        height: parent.height;
                        overflow: elide;
                    }
                }
            }
        }

        // ---- Spectrum plot ----
        Card {
            vertical-stretch: 3;
            VerticalLayout {
                padding: 12px;
                SpectrumPlot {
                    traces: root.traces;
                    y-max-label: root.y-max-label;
                }
            }
        }

        // ---- Samples table ----
        Card {
            vertical-stretch: 4;
            VerticalLayout {
                padding: 8px;
                SamplesTable {
                    rows: root.samples;
                    select-row(i, additive) => { root.select-row(i, additive); }
                }
            }
        }

        // ---- Selection controls ----
        HorizontalLayout {
            height: 32px;
            spacing: 8px;
            alignment: start;
            Text {
                text: "Rename selected:";
                font-size: 12px;
                color: Theme.text-muted;
                vertical-alignment: center;
            }
            LineEdit {
                width: 240px;
                placeholder-text: "new sample ID";
                text <=> root.rename-text;
                accepted => { root.rename-selected(root.rename-text); }
            }
            Button {
                text: "Rename";
                clicked => { root.rename-selected(root.rename-text); }
            }
            Rectangle { horizontal-stretch: 1; }
            Button {
                text: "Delete Selected";
                clicked => { root.remove-selected(); }
            }
        }
    }

    // ---- New-sample overlay ----
    if root.new-sample-open: InputDialog {
        width: 100%;
        height: 100%;
        heading: "New sample";
        prompt: "Name for the new sample";
        ok-text: "Create";
        value <=> root.new-sample-name;
        accept => { root.create-sample(root.new-sample-name); }
        cancel => { root.new-sample-open = false; }
    }

    // ---- Add-constant overlay ----
    if root.custom-open: InputDialog {
        width: 100%;
        height: 100%;
        heading: "Add constant";
        prompt: "Custom conversion constant (ng/µL per A260 absorbance unit)";
        ok-text: "OK";
        value <=> root.custom-input;
        accept => { root.set-custom(root.custom-input); }
        cancel => { root.custom-open = false; }
    }

    // ---- About overlay ----
    if root.about-open: AboutDialog {
        width: 100%;
        height: 100%;
        version: root.version;
        close => { root.about-open = false; }
    }

    // ---- Overwrite-confirm overlay ----
    if root.confirm-overwrite-open: MessageDialog {
        width: 100%;
        height: 100%;
        heading: "Overwrite sample?";
        message: root.confirm-text;
        ok-text: "Overwrite";
        show-cancel: true;
        accept => { root.confirm-overwrite(); }
        cancel => { root.confirm-overwrite-open = false; }
    }

    // ---- Blank-failed alert ----
    if root.blank-fail-open: MessageDialog {
        width: 100%;
        height: 100%;
        heading: "Blank failed";
        message: root.blank-fail-text;
        ok-text: "OK";
        show-cancel: false;
        accept => { root.blank-fail-open = false; }
        cancel => { root.blank-fail-open = false; }
    }

    // ---- Busy overlay (acquiring) — kept last so it sits on top. ----
    if root.busy-open: BusyDialog {
        width: 100%;
        height: 100%;
        message: root.busy-text;
    }
}
