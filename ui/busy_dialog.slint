// Modal "please wait" overlay shown while the instrument is acquiring. It has
// no buttons — the controller opens it, runs the (simulated ~1 s) acquisition,
// and closes it when the reading is in.

import { Theme } from "theme.slint";
import { Card } from "widgets.slint";

export component BusyDialog inherits Rectangle {
    in property <string> message: "Measuring…";
    background: #0b1220bf;

    // Swallow all clicks while busy.
    TouchArea {}

    Card {
        width: 260px;
        height: 96px;
        VerticalLayout {
            padding: 20px;
            alignment: center;
            spacing: 6px;
            Text {
                text: root.message;
                font-size: 15px;
                font-weight: 600;
                color: Theme.text;
                horizontal-alignment: center;
            }
            Text {
                text: "Please wait…";
                font-size: 12px;
                color: Theme.text-muted;
                horizontal-alignment: center;
            }
        }
    }
}
