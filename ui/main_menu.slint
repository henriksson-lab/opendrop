// Main Menu launcher — a User dropdown plus a 3-column grid of module buttons,
// reproducing §7.1 of docs/original_gui_research.md. Only "Nucleic Acid" is
// functional; the rest report a "not implemented yet" banner.

import { ComboBox } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { BevelButton } from "widgets.slint";

// One labelled module tile.
component ModuleTile inherits BevelButton {
    in property <int> index;
    in property <string> module-name;
    callback launch(int, string);
    text: module-name;
    height: 52px;
    clicked => { root.launch(index, module-name); }
}

export component MainMenu inherits Rectangle {
    in property <string> coming-soon: "";
    callback open-module(int, string);
    callback request-exit();

    background: Theme.window-face;

    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        // Menu bar (File | Help) — decorative, matching the original chrome.
        Rectangle {
            height: 22px;
            background: Theme.window-face;
            HorizontalLayout {
                spacing: 16px;
                alignment: start;
                Text { text: "File"; vertical-alignment: center; }
                Text { text: "Help"; vertical-alignment: center; }
            }
        }

        // Title + User account selector.
        HorizontalLayout {
            spacing: 12px;
            alignment: start;
            Text {
                text: "NanoDrop 1000 3.8";
                font-size: 18px;
                font-weight: 700;
                color: Theme.accent;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            Text { text: "User"; vertical-alignment: center; }
            ComboBox {
                width: 180px;
                model: ["Default"];
                current-index: 0;
            }
        }

        // 3-column module grid.
        HorizontalLayout {
            spacing: 14px;

            // Column 1 — application modules.
            VerticalLayout {
                spacing: 8px;
                ModuleTile { index: 0; module-name: "Nucleic Acid"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 1; module-name: "MicroArray"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 2; module-name: "UV-Vis"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 3; module-name: "Cell Cultures"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 4; module-name: "Data Viewer"; launch(i, n) => { root.open-module(i, n); } }
                Rectangle { vertical-stretch: 1; }
            }

            // Column 2 — protein modules.
            VerticalLayout {
                spacing: 8px;
                ModuleTile { index: 5; module-name: "Protein A280"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 6; module-name: "Proteins & Labels"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 7; module-name: "Protein BCA"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 8; module-name: "Protein Bradford"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 9; module-name: "Protein Lowry"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 10; module-name: "Protein Pierce 660nm"; launch(i, n) => { root.open-module(i, n); } }
            }

            // Column 3 — utilities.
            VerticalLayout {
                spacing: 8px;
                ModuleTile { index: 11; module-name: "User's Manual"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 12; module-name: "User Preferences"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 13; module-name: "Utilities & Diagnostics"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 14; module-name: "Dye/Chromophore Editor"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 15; module-name: "Account Management"; launch(i, n) => { root.open-module(i, n); } }
                ModuleTile { index: 16; module-name: "Change Password"; launch(i, n) => { root.open-module(i, n); } }
            }
        }

        // Coming-soon banner (shown when a stubbed module is clicked).
        Text {
            text: root.coming-soon;
            color: #a03030;
            height: 16px;
            horizontal-alignment: center;
        }

        // Wide EXIT button.
        HorizontalLayout {
            alignment: center;
            BevelButton {
                text: "EXIT";
                bold: true;
                width: 220px;
                height: 40px;
                clicked => { root.request-exit(); }
            }
        }
    }
}
