// Shared visual tokens reproducing the ND-1000's Windows-2000/XP grey look:
// a beige-grey window face, 3-D beveled buttons, black text, MS-Sans-Serif-ish
// font. Colours also carry the sample-type "colour key".

export global Theme {
    // Classic Win32 window / control face and 3-D bevel edges.
    out property <color> window-face: #ece9d8;      // XP "3D face"
    out property <color> control-face: #d4d0c8;     // button grey
    out property <color> bevel-light: #ffffff;
    out property <color> bevel-dark: #808080;
    out property <color> bevel-darker: #404040;
    out property <color> text-color: #000000;
    out property <color> disabled-text: #808080;

    // Plot area.
    out property <color> plot-bg: #ffffff;
    out property <color> plot-grid: #d0d8c8;
    out property <color> plot-axis: #000000;
    out property <color> trace: #000000;

    // Header / title accents (XP blue).
    out property <color> accent: #0a5ad0;

    // Sample-type colour key (used for the Sample Type swatch + ng/µL box).
    out property <color> dna-color: #45b545;    // DNA-50, green
    out property <color> rna-color: #e0a020;    // RNA-40, gold
    out property <color> ssdna-color: #40b0c8;  // ssDNA-33, cyan
    out property <color> other-color: #b8b0d8;  // Other, lavender-grey

    out property <length> pad: 6px;
}
