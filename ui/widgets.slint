// Reusable modern flat widgets: a filled/soft push button and a card surface.

import { Theme } from "theme.slint";

// A flat push button. `primary` fills with the accent colour; otherwise it is a
// soft tinted/neutral button. Hover and press states shift the background.
export component Button inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <length> font-size: 13px;
    callback clicked();

    property <bool> hovered: touch.has-hover && enabled;
    property <bool> pressed: touch.pressed && enabled;

    height: 32px;
    // Size to the label so text never clips; 28px of horizontal breathing room.
    min-width: label.preferred-width + 28px;
    border-radius: Theme.radius-sm;

    background: !enabled
        ? Theme.surface-alt
        : primary
            ? (pressed ? Theme.accent-press : hovered ? Theme.accent-hover : Theme.accent)
            : (pressed ? Theme.border-strong : hovered ? Theme.surface-alt : Theme.surface);
    border-width: primary ? 0px : 1px;
    border-color: Theme.border-strong;

    label := Text {
        text: root.text;
        font-size: root.font-size;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        color: !root.enabled
            ? Theme.text-faint
            : root.primary ? Theme.accent-text : Theme.text;
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }
}

// A plain rounded surface with a hairline border used to frame the plot and
// the table.
export component Card inherits Rectangle {
    background: Theme.surface;
    border-radius: Theme.radius;
    border-width: 1px;
    border-color: Theme.border;
    @children
}
